# Database Configuration
# SENSITIVE: Change these values for your environment
APP_DB_URL=jdbc:mysql://localhost:3306/chess_coach_db?serverTimezone=UTC
APP_DB_USERNAME=root
APP_DB_PASSWORD=your_secure_password_here

# Hibernate Configuration
# Options: validate, update, create, create-drop
SPRING_JPA_HIBERNATE_DDL_AUTO=validate

# File Upload Configuration
APP_UPLOAD_BASE_DIR=uploads
APP_UPLOAD_TRAINEE_PHOTO_SUBDIR=trainee-photos
APP_REPORT_EXPORT_DIR=uploads/reports

# Chess.com API Configuration
APP_CHESSCOM_BASE_URL=https://api.chess.com/pub
# SENSITIVE: Update email with your contact email
APP_CHESSCOM_USER_AGENT=ChessCoachMain/1.0 (contact: your-email@example.com)
APP_CHESSCOM_TIMEOUT_SECONDS=15
APP_CHESSCOM_MAX_ARCHIVES=24
APP_CHESSCOM_RETRY_MAX_ATTEMPTS=3
APP_CHESSCOM_RETRY_BACKOFF_MULTIPLIER=2

# Test Data Configuration
# NEVER set to true in production
APP_ALLOW_RESET_TEST_DATA=false

# Coach Default Configuration
# SENSITIVE: Update with your coach information
APP_COACH_DEFAULT_EMAIL=coach@example.com
APP_COACH_DEFAULT_NAME=Your Coach Name
APP_COACH_DEFAULT_PHONE=+1-XXX-XXX-XXXX
